# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/aec_db

# Cloudinary (for admin uploads — Phase 4)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# NextAuth (admin panel — Phase 4)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Password reset (forgot password on admin login)
ADMIN_RESET_SECRET=your-long-random-secret

# Admin seed: npm run seed:admin
# Or add user: npm run seed:admin -- username password "Display Name"
# Default user (arnavadmin) is created when you run npm run seed:admin
